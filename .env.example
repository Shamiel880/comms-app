# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── Email / IMAP ─────────────────────────────────────────
# For Gmail: use App Password (Settings → Security → App Passwords)
# For self-hosted: your Dovecot/Mailcow credentials
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=you@yourdomain.com
EMAIL_PASS=your-app-password
EMAIL_TLS=true

# SMTP (outbound / replies)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@yourdomain.com
SMTP_PASS=your-app-password

# ─── WhatsApp (Meta Cloud API) ────────────────────────────
# Get these from: developers.facebook.com → your app → WhatsApp
WA_VERIFY_TOKEN=pick-any-secret-string
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=

# ─── Telegram ─────────────────────────────────────────────
# Get token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your public HTTPS URL (use ngrok for local testing)
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# ─── AI (Anthropic) ───────────────────────────────────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Mode ─────────────────────────────────────────────────
# Set to "mock" to run fully without any real credentials
# Set to "live" to use real integrations
MODE=mock
