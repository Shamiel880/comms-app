<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>0bc2e4d5-b6ab-424c-b5c9-5563c35d6677</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>LEMCO</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="LEMCO Tagger"/>
  <Description DefaultValue="Tag emails for LEMCO Priority OS"/>
  <IconUrl DefaultValue="https://outlook-addin-ruddy.vercel.app/icon.png"/>
  <HighResolutionIconUrl DefaultValue="https://outlook-addin-ruddy.vercel.app/icon.png"/>
  <SupportUrl DefaultValue="https://outlook-addin-ruddy.vercel.app"/>

  <AppDomains>
    <AppDomain>https://outlook-addin-ruddy.vercel.app</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://outlook-addin-ruddy.vercel.app/taskpane.html"/>
        <RequestedHeight>220</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

</OfficeApp>
